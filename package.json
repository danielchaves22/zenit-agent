{
  "name": "myagent",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm -r --if-present --parallel dev",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "build:turbo": "turbo run build --dangerously-disable-package-manager-check",
    "dev:turbo": "turbo run dev --parallel --dangerously-disable-package-manager-check",
    "lint:turbo": "turbo run lint --dangerously-disable-package-manager-check",
    "typecheck:turbo": "turbo run typecheck --dangerously-disable-package-manager-check",
    "test:turbo": "turbo run test --dangerously-disable-package-manager-check"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.9.3"
  }
}
